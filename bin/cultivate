#!/bin/bash

set -e
trap 'echo -e "Error on line $LINENO"' ERR

########################################
# Configuration
########################################

COMPOSE_FILE="./docker/docker-compose.yml"
BASE_URL="http://localhost"
PORTS=(
  ${SERVER_PORT:-8080}
  ${DB_PORT:-3306}
  ${VITE_PORT:-5173}
  1080
  ${MAIL_PORT:-1025}
)
CONTAINERS=(
  "${APACHE_HOST:-ivy_apache}"
  "${DB_HOST:-ivy_mysql}"
  "${NODE_HOST:-ivy_node}"
  "${MAIL_HOST:-ivy_mailcatcher}"
)

GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RESET="\033[0m"

########################################
# UX Helper
########################################

finish_status() {
  echo -e "${GREEN}[✓] $1${RESET}"
}

########################################
# Load .env
########################################

if [ -f .env ]; then
  while IFS='=' read -r key value; do
    [[ -z "$key" || "$key" =~ ^# ]] && continue
    value="${value%\"}"
    value="${value#\"}"
    export "$key=$value"
  done < .env
fi

if [ "${APP_ENV}" != "development" ]; then
  echo "This script can only run in a development environment."
  exit 1
fi

########################################
# Docker or Podman detection
########################################

if command -v docker >/dev/null 2>&1; then
    if docker compose version >/dev/null 2>&1; then
        COMPOSE_CMD="docker compose"
    else
        COMPOSE_CMD="docker-compose"
    fi
elif command -v podman >/dev/null 2>&1; then
    if podman compose version >/dev/null 2>&1; then
        COMPOSE_CMD="podman compose"
    else
        COMPOSE_CMD="podman-compose"
    fi
else
    echo "Neither Docker nor Podman is installed."
    exit 1
fi

########################################
# Dev Runner
########################################

run_dev() {

  ########################################
  # Port Checks
  ########################################

  PORT_CONFLICTS=()

  for PORT in "${PORTS[@]}"; do
    if lsof -iTCP:"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
      PORT_CONFLICTS+=("$PORT")
    fi
  done

  if [ ${#PORT_CONFLICTS[@]} -ne 0 ]; then
    echo "The following ports are already in use:"
    echo ""
    for PORT in "${PORT_CONFLICTS[@]}"; do
      echo " :$PORT"
    done
    echo ""
    exit 1
  fi

  finish_status "Required ports available"

  ########################################
  # Start Containers
  ########################################

  $COMPOSE_CMD -f "$COMPOSE_FILE" up -d

  ########################################
  # Wait for containers
  ########################################

  wait_for_containers() {
    local containers=("$@")

    local max_len=0
    for c in "${containers[@]}"; do
      (( ${#c} > max_len )) && max_len=${#c}
    done

    local col_width=$((max_len + 2))

    for container in "${containers[@]}"; do
      printf "${YELLOW} ⠿ Container %-*s%-7s${RESET}\r" \
        "$col_width" "$container" "Waiting"

      until [ "$($COMPOSE_CMD -f "$COMPOSE_FILE" ps -q "$container" | xargs docker inspect -f '{{.State.Running}}' 2>/dev/null)" = "true" ]; do
        sleep 0.2
      done

      printf "\r\033[2K"
      printf "${GREEN} ⠿ Container %-*s%-7s${RESET}\n" \
        "$col_width" "$container" "Ready"
    done
  }

  wait_for_containers "${CONTAINERS[@]}"

  ########################################
  # Node Setup (uses running container)
  ########################################

  if ! $COMPOSE_CMD -f "$COMPOSE_FILE" exec -T node test -d node_modules; then
    $COMPOSE_CMD -f "$COMPOSE_FILE" run --rm node npm install
  fi

  finish_status "Node dependencies ready"

  ########################################
  # Start Dev Server
  ########################################

  $COMPOSE_CMD -f "$COMPOSE_FILE" exec -d node npm run dev -- --host 0.0.0.0

  finish_status "Vite dev server running"

  ########################################
  # Output URLs
  ########################################

  echo ""
  echo "Mailcatcher:      ${BASE_URL}:1080"
  echo "Vite Dev Server:  ${BASE_URL}:${VITE_PORT:-5173}"
  echo "Application:      ${BASE_URL}:${SERVER_PORT:-8080}"
  echo ""
}

########################################
# Build Runner (fully independent)
########################################

run_build() {

  ENTRY_FILE=".build/vite-entries.json"

  mkdir -p .build

  ########################################
  # Generate Vite entries
  ########################################

  echo "{" > "$ENTRY_FILE"
  FIRST=true

  while IFS= read -r file; do
      name="$file"

      if [ "$FIRST" = true ]; then
          FIRST=false
      else
          echo "," >> "$ENTRY_FILE"
      fi

      json_name=$(printf '%s' "$name" | sed 's/\\/\\\\/g; s/"/\\"/g')
      json_file=$(printf '%s' "$file" | sed 's/\\/\\\\/g; s/"/\\"/g')

      echo "  \"$json_name\": \"$json_file\"" >> "$ENTRY_FILE"

  done < <(find plugins templates -type f \( -name "*.js" -o -name "*.css" \) ! -path "*/node_modules/*" | sort)

  echo "}" >> "$ENTRY_FILE"

  finish_status "Vite entries generated"

  ########################################
  # Node dependencies
  ########################################

  if ! $COMPOSE_CMD -f "$COMPOSE_FILE" run --rm node test -d node_modules; then
    $COMPOSE_CMD -f "$COMPOSE_FILE" run --rm node npm install
  fi

  finish_status "Node dependencies ready"

  ########################################
  # Run Vite build
  ########################################

  $COMPOSE_CMD -f "$COMPOSE_FILE" run --rm node npm run build

  finish_status "JS & CSS built successfully"

  ########################################
  # Cleanup
  ########################################

  rm -rf .build
  finish_status ".build folder removed"
}

########################################
# Command Dispatcher
########################################

COMMAND=$1
[ -z "$COMMAND" ] && COMMAND="run"

case "$COMMAND" in
  run)
    run_dev
    ;;
  build)
    run_build
    ;;
  stop)
    $COMPOSE_CMD -f "$COMPOSE_FILE" down
    ;;
  restart)
    $COMPOSE_CMD -f "$COMPOSE_FILE" down
    run_dev
    ;;
  *)
    echo "Usage: $0 {run|build|stop|restart}"
    exit 1
    ;;
esac