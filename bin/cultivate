#!/bin/bash

set -e
trap 'echo -e "Error on line $LINENO"' ERR

########################################
# Configuration
########################################

COMPOSE_FILE="./docker/docker-compose.yml"
BASE_URL="http://localhost"
ENTRY_FILE=".build/vite-entries.json"
PACKAGE_DIR=".package"
DIST_FILE="ivy-package.zip"

PORTS=(
  ${SERVER_PORT:-8080}
  ${DB_PORT:-3306}
  ${VITE_PORT:-5173}
  1080
  ${MAIL_PORT:-1025}
)

CONTAINERS=(
  "${APACHE_HOST:-ivy_apache}"
  "${DB_HOST:-ivy_mysql}"
  "${NODE_HOST:-ivy_node}"
  "${MAIL_HOST:-ivy_mailcatcher}"
)

NODE_CONTAINER="${NODE_HOST:-ivy_node}"

GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RESET="\033[0m"

########################################
# UX Helper
########################################

finish_status() {
  echo -e "${GREEN}[✓] $1${RESET}"
}

########################################
# Load .env
########################################

if [ -f .env ]; then
  while IFS='=' read -r key value; do
    [[ -z "$key" || "$key" =~ ^# ]] && continue
    value="${value%\"}"
    value="${value#\"}"
    export "$key=$value"
  done < .env
fi

if [ "${APP_ENV}" != "development" ]; then
  echo "This script can only run in a development environment."
  exit 1
fi

########################################
# Engine Detection (Docker / Podman)
########################################

if command -v docker >/dev/null 2>&1; then
  ENGINE="docker"
elif command -v podman >/dev/null 2>&1; then
  ENGINE="podman"
else
  echo "Neither Docker nor Podman is installed."
  exit 1
fi

# Compose command detection
if $ENGINE compose version >/dev/null 2>&1; then
  COMPOSE_CMD="$ENGINE compose"
else
  COMPOSE_CMD="$ENGINE-compose"
fi

########################################
# Container Helpers
########################################

is_container_running() {
  $ENGINE inspect -f '{{.State.Running}}' "$1" 2>/dev/null | grep -q true
}

wait_for_containers() {
  local containers=("$@")

  local max_len=0
  for c in "${containers[@]}"; do
    (( ${#c} > max_len )) && max_len=${#c}
  done

  local col_width=$((max_len + 2))

  for container in "${containers[@]}"; do
    printf "${YELLOW} ⠿ Container %-*s%-7s${RESET}\r" \
      "$col_width" "$container" "Waiting"

    until is_container_running "$container"; do
      sleep 0.2
    done

    printf "\r\033[2K"
    printf "${GREEN} ⠿ Container %-*s%-7s${RESET}\n" \
      "$col_width" "$container" "Ready"
  done
}

########################################
# Port Checks
########################################

check_ports() {
  if ! command -v lsof >/dev/null 2>&1; then
    echo "Warning: lsof not installed, skipping port checks"
    return
  fi

  PORT_CONFLICTS=()

  for PORT in "${PORTS[@]}"; do
    if lsof -iTCP:"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
      PORT_CONFLICTS+=("$PORT")
    fi
  done

  if [ ${#PORT_CONFLICTS[@]} -ne 0 ]; then
    echo "The following ports are already in use:"
    echo ""
    for PORT in "${PORT_CONFLICTS[@]}"; do
      echo " :$PORT"
    done
    echo ""
    exit 1
  fi

  finish_status "Required ports available"
}

########################################
# Node Helpers (EXEC ONLY)
########################################

node_exec() {
  $ENGINE exec -i "$NODE_CONTAINER" "$@"
}

node_exec_bg() {
  $ENGINE exec -d "$NODE_CONTAINER" "$@"
}

setup_node() {
  if ! node_exec test -d node_modules; then
    node_exec npm install
  fi

  finish_status "Node dependencies ready"
}

########################################
# Dev Runner
########################################

run_dev() {

  ########################################
  # Ports
  ########################################

  check_ports

  ########################################
  # Start Containers
  ########################################

  $COMPOSE_CMD -f "$COMPOSE_FILE" up -d

  ########################################
  # Wait for Containers
  ########################################

  wait_for_containers "${CONTAINERS[@]}"

  ########################################
  # Node Setup
  ########################################

  setup_node

  ########################################
  # Start Vite
  ########################################

  node_exec_bg npm run dev -- --host 0.0.0.0

  finish_status "Vite dev server running"

  ########################################
  # Output URLs
  ########################################

  echo ""
  echo "Mailcatcher:      ${BASE_URL}:1080"
  echo "Vite Dev Server:  ${BASE_URL}:${VITE_PORT:-5173}"
  echo "Application:      ${BASE_URL}:${SERVER_PORT:-8080}"
  echo ""
}

########################################
# Build Runner
########################################

run_build() {

  TARGET=$2
  if [ -z "$TARGET" ]; then
    echo "Usage: $0 build {template:name|plugin:name}"
    exit 1
  fi

  TYPE=$(echo "$TARGET" | cut -d':' -f1)
  NAME=$(echo "$TARGET" | cut -d':' -f2)

  if [ "$TYPE" = "template" ]; then
    BASE_PATH="templates/$NAME"
  elif [ "$TYPE" = "plugin" ]; then
    BASE_PATH="plugins/$NAME"
  else
    echo "Unknown type: $TYPE (use template or plugin)"
    exit 1
  fi

  if [ ! -d "$BASE_PATH" ]; then
    echo "Path not found: $BASE_PATH"
    exit 1
  fi

  DIST_PATH="$BASE_PATH/dist"

  # Remove old dist folder
  if [ -d "$DIST_PATH" ]; then
    rm -rf "$DIST_PATH"
    finish_status "Old dist folder removed for $TARGET"
  fi
  mkdir -p "$DIST_PATH"

  # Ensure Node dependencies
  setup_node

  ########################################
  # Build CSS entries individually (Tailwind processed)
  ########################################
  $ENGINE exec -i \
    -e BUILD_PATH="$BASE_PATH" \
    "$NODE_CONTAINER" \
    npx vite build
  finish_status "CSS files built and processed for $TARGET"
}

########################################
# Package Runner
########################################

run_package() {

  ########################################
  # Step 1: Build assets
  ########################################

  run_build

  ########################################
  # Step 2: Prepare package directory
  ########################################

  rm -rf "$PACKAGE_DIR"
  mkdir -p "$PACKAGE_DIR"

  ########################################
  # Step 3: Copy required folders
  ########################################

  cp -r public "$PACKAGE_DIR/"
  cp -r plugins "$PACKAGE_DIR/"
  cp -r templates "$PACKAGE_DIR/"
  cp -r routes "$PACKAGE_DIR/"
  cp -r language "$PACKAGE_DIR/"

  ########################################
  # Step 4: Copy required files
  ########################################

  [ -f autoloader.php ] && cp autoloader.php "$PACKAGE_DIR/"
  [ -f .env ] && cp .env "$PACKAGE_DIR/"
  cp composer.json "$PACKAGE_DIR/"
  [ -f composer.lock ] && cp composer.lock "$PACKAGE_DIR/"

  finish_status "Package files copied"

  ########################################
  # Step 5: Install production dependencies
  ########################################

  (cd "$PACKAGE_DIR" && composer install --no-dev --optimize-autoloader)

  finish_status "Composer production dependencies installed"

  ########################################
  # Step 6: Create ZIP
  ########################################

  rm -f "$DIST_FILE"
  (cd "$PACKAGE_DIR" && zip -r "../$DIST_FILE" . > /dev/null)

  finish_status "Package created: $DIST_FILE"

  ########################################
  # Step 7: Cleanup
  ########################################

  rm -rf "$PACKAGE_DIR"
  finish_status "Temporary package folder removed"
}

########################################
# Commands
########################################

COMMAND=$1
SUBCOMMAND=$2
[ -z "$COMMAND" ] && COMMAND="run"

case "$COMMAND" in
  run)
    run_dev
    ;;
  build)
    run_build "$@"
    ;;
  package)
    run_package
    ;;
  stop)
    $COMPOSE_CMD -f "$COMPOSE_FILE" down
    ;;
  restart)
    $COMPOSE_CMD -f "$COMPOSE_FILE" down
    run_dev
    ;;
  *)
    echo "Usage: $0 {run|build|package|stop|restart}"
    exit 1
    ;;
esac