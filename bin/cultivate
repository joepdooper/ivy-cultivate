#!/bin/bash

set -e
trap 'echo -e "Error on line $LINENO"' ERR

########################################
# Configuration
########################################

COMPOSE_FILE="./docker/docker-compose.yml"
BASE_URL="http://localhost"

PORTS=(
  ${SERVER_PORT:-8080}
  ${DB_PORT:-3306}
  ${VITE_PORT:-5173}
  1080
  ${MAIL_PORT:-1025}
)

CONTAINERS=(
  "${APACHE_HOST:-ivy_apache}"
  "${DB_HOST:-ivy_mysql}"
  "${NODE_HOST:-ivy_node}"
  "${MAIL_HOST:-ivy_mailcatcher}"
)

NODE_CONTAINER="${NODE_HOST:-ivy_node}"

GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RESET="\033[0m"

########################################
# UX Helper
########################################

finish_status() {
  echo -e "${GREEN}[✓] $1${RESET}"
}

########################################
# Load .env
########################################

if [ -f .env ]; then
  while IFS='=' read -r key value; do
    [[ -z "$key" || "$key" =~ ^# ]] && continue
    value="${value%\"}"
    value="${value#\"}"
    export "$key=$value"
  done < .env
fi

if [ "${APP_ENV}" != "development" ]; then
  echo "This script can only run in a development environment."
  exit 1
fi

########################################
# Engine Detection (Docker / Podman)
########################################

if command -v docker >/dev/null 2>&1; then
  ENGINE="docker"
elif command -v podman >/dev/null 2>&1; then
  ENGINE="podman"
else
  echo "Neither Docker nor Podman is installed."
  exit 1
fi

# Compose command detection
if $ENGINE compose version >/dev/null 2>&1; then
  COMPOSE_CMD="$ENGINE compose"
else
  COMPOSE_CMD="$ENGINE-compose"
fi

########################################
# Container Helpers
########################################

is_container_running() {
  $ENGINE inspect -f '{{.State.Running}}' "$1" 2>/dev/null | grep -q true
}

wait_for_containers() {
  local containers=("$@")

  local max_len=0
  for c in "${containers[@]}"; do
    (( ${#c} > max_len )) && max_len=${#c}
  done

  local col_width=$((max_len + 2))

  for container in "${containers[@]}"; do
    printf "${YELLOW} ⠿ Container %-*s%-7s${RESET}\r" \
      "$col_width" "$container" "Waiting"

    until is_container_running "$container"; do
      sleep 0.2
    done

    printf "\r\033[2K"
    printf "${GREEN} ⠿ Container %-*s%-7s${RESET}\n" \
      "$col_width" "$container" "Ready"
  done
}

########################################
# Port Checks
########################################

check_ports() {
  if ! command -v lsof >/dev/null 2>&1; then
    echo "Warning: lsof not installed, skipping port checks"
    return
  fi

  PORT_CONFLICTS=()

  for PORT in "${PORTS[@]}"; do
    if lsof -iTCP:"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
      PORT_CONFLICTS+=("$PORT")
    fi
  done

  if [ ${#PORT_CONFLICTS[@]} -ne 0 ]; then
    echo "The following ports are already in use:"
    echo ""
    for PORT in "${PORT_CONFLICTS[@]}"; do
      echo " :$PORT"
    done
    echo ""
    exit 1
  fi

  finish_status "Required ports available"
}

########################################
# Node Helpers (EXEC ONLY)
########################################

node_exec() {
  $ENGINE exec -i "$NODE_CONTAINER" "$@"
}

node_exec_bg() {
  $ENGINE exec -d "$NODE_CONTAINER" "$@"
}

setup_node() {
  if ! node_exec test -d node_modules; then
    node_exec npm install
  fi

  finish_status "Node dependencies ready"
}

########################################
# Dev Runner
########################################

run_dev() {

  ########################################
  # Ports
  ########################################

  check_ports

  ########################################
  # Start Containers
  ########################################

  $COMPOSE_CMD -f "$COMPOSE_FILE" up -d

  ########################################
  # Wait for Containers
  ########################################

  wait_for_containers "${CONTAINERS[@]}"

  ########################################
  # Node Setup
  ########################################

  setup_node

  ########################################
  # Start Vite
  ########################################

  node_exec_bg npm run dev -- --host 0.0.0.0

  finish_status "Vite dev server running"

  ########################################
  # Output URLs
  ########################################

  echo ""
  echo "Mailcatcher:      ${BASE_URL}:1080"
  echo "Vite Dev Server:  ${BASE_URL}:${VITE_PORT:-5173}"
  echo "Application:      ${BASE_URL}:${SERVER_PORT:-8080}"
  echo ""
}

########################################
# Build Runner
########################################

run_build() {

  ENTRY_FILE=".build/vite-entries.json"

  mkdir -p .build

  ########################################
  # Generate entries
  ########################################

  echo "{" > "$ENTRY_FILE"
  FIRST=true

  while IFS= read -r file; do
    if [ "$FIRST" = true ]; then
      FIRST=false
    else
      echo "," >> "$ENTRY_FILE"
    fi

    json_name=$(printf '%s' "$file" | sed 's/\\/\\\\/g; s/"/\\"/g')
    json_file="$json_name"

    echo "  \"$json_name\": \"$json_file\"" >> "$ENTRY_FILE"

  done < <(find plugins templates -type f \( -name "*.js" -o -name "*.css" \) ! -path "*/node_modules/*" | sort)

  echo "}" >> "$ENTRY_FILE"

  finish_status "Vite entries generated"

  ########################################
  # Ensure containers running
  ########################################

  $COMPOSE_CMD -f "$COMPOSE_FILE" up -d
  wait_for_containers "${CONTAINERS[@]}"

  ########################################
  # Node Setup
  ########################################

  setup_node

  ########################################
  # Build
  ########################################

  node_exec npm run build

  finish_status "JS & CSS built successfully"

  ########################################
  # Cleanup
  ########################################

  rm -rf .build
  finish_status ".build folder removed"
}

########################################
# Commands
########################################

COMMAND=$1
[ -z "$COMMAND" ] && COMMAND="run"

case "$COMMAND" in
  run)
    run_dev
    ;;
  build)
    run_build
    ;;
  stop)
    $COMPOSE_CMD -f "$COMPOSE_FILE" down
    ;;
  restart)
    $COMPOSE_CMD -f "$COMPOSE_FILE" down
    run_dev
    ;;
  *)
    echo "Usage: $0 {run|build|stop|restart}"
    exit 1
    ;;
esac